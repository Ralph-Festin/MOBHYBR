<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="finals.ConverterPage"
             Title="ConverterPage"
             BackgroundColor="#365FC9">
    <VerticalStackLayout>
        <Label Text="Currency Converter"
               FontSize="28"
               FontAttributes="Bold"
               TextColor="White"
               HorizontalOptions="Center"
               Margin="0, 10"/>
        
        <Grid>
            <BoxView Color="White"
                     CornerRadius="20" 
                     Margin="30"/>

            <Grid ColumnDefinitions="*, *, *"
                  RowDefinitions="Auto, Auto, Auto"
                  RowSpacing="20"
                  Margin="10"
                  Padding="40">

                <Label Text="Date: "
                       HorizontalOptions="Start"
                       VerticalTextAlignment="Center" />

                <DatePicker x:Name="DatePicker" 
                            Margin="50, 0, 0, 0"/>

                <Picker Grid.Row="1" Grid.Column="0"
                        x:Name="FromCurrency"
                        Title="From:"
                        HorizontalOptions="Fill"/>

                <Image Grid.Row="1" Grid.Column="1"
                       Source="arrow.png"
                       HeightRequest="40"
                       HorizontalOptions="Center"
                       VerticalOptions="End"/>

                <Picker Grid.Row="1" Grid.Column="2"
                        x:Name="ToCurrency"
                        Title="To:"
                        HorizontalOptions="Fill"/>

                <Entry Grid.Row="2" Grid.Column="0"
                       x:Name="AmountEntry"
                       Placeholder="Input amount here..."
                       HorizontalOptions="Fill" />

                <Button Grid.Row="2" Grid.Column="1"
                        Clicked="OnConvertButtonClicked"
                        Text="Convert"
                        FontAttributes="Bold"
                        BackgroundColor="#365FC9"
                        TextColor="White"
                        HorizontalOptions="Center"/>

                <Border Grid.Row="2" Grid.Column="2"
                        Stroke="LightGray"
                        HorizontalOptions="Fill">
                    <Label x:Name="ResultAmount"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"/>
                </Border>
            </Grid>
        </Grid>
        <Button Text="Back to Home"
                Clicked="OnBackToHomeClicked"
                FontAttributes="Bold"
                BackgroundColor="White"
                TextColor="Black"
                HorizontalOptions="Center"/>
    </VerticalStackLayout>
</ContentPage>