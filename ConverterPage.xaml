<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="finals.ConverterPage"
             BackgroundColor="#2F5BEA">

    <ScrollView>
        <VerticalStackLayout Padding="10,8" Spacing="10">

            <!-- HEADER -->
            <Frame BackgroundColor="White"
                   CornerRadius="16"
                   Padding="12"
                   HasShadow="True">

                <VerticalStackLayout Spacing="6">

                    <Label Text="Currency Converter"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#2F5BEA"
                           HorizontalOptions="Center"/>

                    <Label Text="Convert currencies instantly"
                           FontSize="12"
                           TextColor="Gray"
                           HorizontalOptions="Center"/>

                </VerticalStackLayout>

            </Frame>

            <!-- MAIN CARD -->
            <Frame BackgroundColor="White"
                   CornerRadius="16"
                   Padding="12"
                   HasShadow="True">

                <VerticalStackLayout Spacing="10">

                    <!-- DATE -->
                    <Label Text="Date"
                           FontAttributes="Bold"
                           TextColor="#2F5BEA"/>

                    <DatePicker x:Name="DatePicker"/>

                    <!-- FROM + TO SAME ROW -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                        <!-- FROM -->
                        <VerticalStackLayout Spacing="6">

                            <Label Text="From"
                                   FontAttributes="Bold"
                                   TextColor="#2F5BEA"/>

                            <Entry x:Name="FromSearchEntry"
                                   Placeholder="From"
                                   TextChanged="OnFromSearchChanged"
                                   Focused="OnFromFocused"
                                   BackgroundColor="#F2F4FF"
                                   HeightRequest="40"/>

                            <Frame x:Name="FromDropdown"
                                   IsVisible="False"
                                   HeightRequest="110"
                                   BackgroundColor="White"
                                   BorderColor="#D0D7FF"
                                   CornerRadius="10"
                                   Padding="0"
                                   HasShadow="True">

                                <CollectionView x:Name="FromCollection"
                                                SelectionMode="Single"
                                                SelectionChanged="OnFromSelected">

                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Frame Padding="6"
                                                   Margin="2"
                                                   CornerRadius="6"
                                                   BackgroundColor="#F7F9FF">

                                                <Label Text="{Binding PickerDisplay}"
                                                       FontSize="13"/>
                                            </Frame>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>

                                </CollectionView>

                            </Frame>

                        </VerticalStackLayout>

                        <!-- TO -->
                        <VerticalStackLayout Grid.Column="1" Spacing="6">

                            <Label Text="To"
                                   FontAttributes="Bold"
                                   TextColor="#2F5BEA"/>

                            <Entry x:Name="ToSearchEntry"
                                   Placeholder="To"
                                   TextChanged="OnToSearchChanged"
                                   Focused="OnToFocused"
                                   BackgroundColor="#F2F4FF"
                                   HeightRequest="40"/>

                            <Frame x:Name="ToDropdown"
                                   IsVisible="False"
                                   HeightRequest="110"
                                   BackgroundColor="White"
                                   BorderColor="#D0D7FF"
                                   CornerRadius="10"
                                   Padding="0"
                                   HasShadow="True">

                                <CollectionView x:Name="ToCollection"
                                                SelectionMode="Single"
                                                SelectionChanged="OnToSelected">

                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Frame Padding="6"
                                                   Margin="2"
                                                   CornerRadius="6"
                                                   BackgroundColor="#F7F9FF">

                                                <Label Text="{Binding PickerDisplay}"
                                                       FontSize="13"/>
                                            </Frame>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>

                                </CollectionView>

                            </Frame>

                        </VerticalStackLayout>

                    </Grid>

                    <!-- AMOUNT -->
                    <Label Text="Amount"
                           FontAttributes="Bold"
                           TextColor="#2F5BEA"/>

                    <Entry x:Name="AmountEntry"
                           Placeholder="Enter amount"
                           Keyboard="Numeric"
                           BackgroundColor="#F2F4FF"
                           HeightRequest="40"/>

                    <!-- CONVERT -->
                    <Button Text="Convert"
                            Clicked="OnConvertButtonClicked"
                            BackgroundColor="#2F5BEA"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="40"/>

                    <!-- RESULT -->
                    <Frame BackgroundColor="#EEF2FF"
                           CornerRadius="14"
                           Padding="10"
                           HasShadow="False">

                        <VerticalStackLayout Spacing="2">

                            <Label Text="Converted Amount"
                                   FontSize="11"
                                   TextColor="Gray"
                                   HorizontalOptions="Center"/>

                            <Label x:Name="ResultAmount"
                                   Text="0.00"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#2F5BEA"
                                   HorizontalTextAlignment="Center"/>

                        </VerticalStackLayout>

                    </Frame>

                </VerticalStackLayout>

            </Frame>

            <!-- BACK -->
            <Button Text="Back to Home"
                    Clicked="OnBackToHomeClicked"
                    BackgroundColor="White"
                    TextColor="#2F5BEA"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="40"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>