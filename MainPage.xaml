<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="finals.MainPage"
             BackgroundColor="#2F5BEA">

    <ScrollView>
        <VerticalStackLayout Padding="10,8" Spacing="10">

            <!-- HEADER -->
            <Frame BackgroundColor="White"
                   CornerRadius="16"
                   Padding="12"
                   HasShadow="True">

                <VerticalStackLayout Spacing="6">

                    <Label Text="CurrencyX"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#2F5BEA"
                           HorizontalOptions="Center"/>

                    <Label Text="Live Currency Exchange Tracker"
                           FontSize="12"
                           TextColor="Gray"
                           HorizontalOptions="Center"/>

                    <Button Text="Go to Currency Converter"
                            Clicked="OnConverterPageClicked"
                            BackgroundColor="#2F5BEA"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="40"/>
                </VerticalStackLayout>

            </Frame>

            <!-- MAIN CARD -->
            <Frame BackgroundColor="White"
                   CornerRadius="16"
                   Padding="12"
                   HasShadow="True">

                <VerticalStackLayout Spacing="8">

                    <Label Text="Select Date &amp; Base Currency"
                           FontAttributes="Bold"
                           TextColor="#2F5BEA"
                           HorizontalOptions="Center"/>

                    <!-- SAME ROW -->
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">

                        <DatePicker x:Name="DatePicker"
                                    Grid.Column="0"
                                    DateSelected="OnDateChanged"/>

                        <Entry x:Name="CurrencySearchEntry"
                               Grid.Column="1"
                               Placeholder="Search currency"
                               TextChanged="OnCurrencySearchChanged"
                               Focused="OnCurrencyFocused"
                               BackgroundColor="#F2F4FF"
                               HeightRequest="40"/>
                    </Grid>

                    <!-- DROPDOWN -->
                    <Frame x:Name="CurrencyDropdownFrame"
                           IsVisible="False"
                           HeightRequest="160"
                           BackgroundColor="White"
                           BorderColor="#D0D7FF"
                           CornerRadius="10"
                           Padding="0"
                           HasShadow="True">

                        <CollectionView x:Name="CurrencySearchCollection"
                                        SelectionMode="Single"
                                        SelectionChanged="OnCurrencySelected">

                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame Padding="8"
                                           Margin="3"
                                           CornerRadius="6"
                                           BackgroundColor="#F7F9FF">

                                        <Label Text="{Binding PickerDisplay}"
                                               FontSize="13"/>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                        </CollectionView>

                    </Frame>

                </VerticalStackLayout>
            </Frame>

            <!-- RATES -->
            <Frame BackgroundColor="White"
                   CornerRadius="16"
                   Padding="0"
                   HasShadow="True">

                <CollectionView x:Name="CurrenciesCollection"
                                HeightRequest="180">

                    <CollectionView.Header>
                        <Grid ColumnDefinitions="*,*"
                              Padding="8"
                              BackgroundColor="#EEF2FF">

                            <Label Text="Currency"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"/>

                            <Label Grid.Column="1"
                                   Text="Rate"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"/>
                        </Grid>
                    </CollectionView.Header>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,*"
                                  Padding="8">

                                <Label Text="{Binding CurrencyCode}"
                                       HorizontalTextAlignment="Center"/>

                                <Label Grid.Column="1"
                                       Text="{Binding Rate}"
                                       HorizontalTextAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>

            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>